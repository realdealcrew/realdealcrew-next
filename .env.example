# HighLevel (GoHighLevel)
# Your Sub-Account API key — found in GHL > Settings > Integrations > API Key
HIGHLEVEL_API_KEY=

# Your Sub-Account Location ID — found in GHL > Settings > Business Info
HIGHLEVEL_LOCATION_ID=

# TidyCal
# Your booking slug — the path after tidycal.com/ e.g. "realdealcrew/fit-call"
NEXT_PUBLIC_TIDYCAL_SLUG=realdealcrew/fit-call
